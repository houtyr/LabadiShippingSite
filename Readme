    <script>
        const modal = document.getElementById('leadModal');
        const modalContainer = modal.querySelector('div');
        const leadForm = document.getElementById('leadForm');
        const successMessage = document.getElementById('successMessage');
        const errorMessage = document.getElementById('errorMessage');
        const submitBtn = document.getElementById('submitBtn');

        function toggleModal(show) {
            if (show) {
                modal.style.display = 'flex';
                void modal.offsetHeight;
                modal.classList.remove('opacity-0');
                modal.classList.add('opacity-100');
                modalContainer.classList.remove('scale-95');
                modalContainer.classList.add('scale-100');
            } else {
                modal.classList.remove('opacity-100');
                modal.classList.add('opacity-0');
                modalContainer.classList.remove('scale-100');
                modalContainer.classList.add('scale-95');
                setTimeout(() => { modal.style.display = 'none'; resetModalState(); }, 300);
            }
        }

        function resetModalState() {
            leadForm.style.display = 'block';
            successMessage.style.display = 'none';
            errorMessage.style.display = 'none';
            errorMessage.innerText = '';
            submitBtn.disabled = false;
            leadForm.reset();
            if (window.turnstile) { turnstile.reset(); }
        }

        async function handleFormSubmit(e) {
            e.preventDefault();
            errorMessage.classList.add('hidden');
            submitBtn.disabled = true;

            const email = document.getElementById('emailInput').value;
            const destination = document.getElementById('routeDestination').value;
            const turnstileResponse = leadForm.querySelector('[name="cf-turnstile-response"]').value;

            if (!turnstileResponse) {
                showError("Please complete the security verification puzzle.");
                submitBtn.disabled = false;
                return;
            }

            try {
                const response = await fetch('/api/leads', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        email: email,
                        origin: 'Massachusetts / New England',
                        destination: destination,
                        turnstileToken: turnstileResponse
                    })
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    leadForm.style.display = 'none';
                    successMessage.style.display = 'flex';
                    setTimeout(() => { toggleModal(false); }, 3000);
                } else {
                    showError(result.error || "An unexpected system error occurred processing your request.");
                    submitBtn.disabled = false;
                }
            } catch (err) {
                showError("Network connection failure. Verify internet connectivity.");
                submitBtn.disabled = false;
            }
        }

        function showError(msg) {
            errorMessage.innerText = msg;
            errorMessage.classList.remove('hidden');
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && modal.style.display === 'flex') { toggleModal(false); }
        });
    </script>
</body>
</html>


Javascript
export async function onRequestPost(context) {
    const { env } = context;
    
    try {
        // Parse incoming request payload safely
        const payload = await context.request.json();
        const { email, origin, destination, turnstileToken } = payload;

        // Validation Tier 1: Parameter Existence Check
        if (!email || !origin || !destination || !turnstileToken) {
            return new Response(JSON.stringify({ success: false, error: "Missing required registration structural fields." }), {
                status: 400,
                headers: { "Content-Type": "application/json" }
            });
        }

        // Validation Tier 2: Email Expression Formatting Pattern Standard Enforcement
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(email) || email.length > 254) {
            return new Response(JSON.stringify({ success: false, error: "Invalid email syntax format structure." }), {
                status: 400,
                headers: { "Content-Type": "application/json" }
            });
        }

        // Validation Tier 3: Cryptographic Turnstile Verification Challenge Handling
        const verifyEndpoint = "[https://challenges.cloudflare.com/turnstile/v0/siteverify](https://challenges.cloudflare.com/turnstile/v0/siteverify)";
        const challengeForm = new FormData();
        challengeForm.append("secret", env.TURNSTILE_SECRET_KEY);
        challengeForm.append("response", turnstileToken);
        challengeForm.append("remoteip", context.request.headers.get("CF-Connecting-IP"));

        const tokenVerificationResult = await fetch(verifyEndpoint, {
            method: "POST",
            body: challengeForm
        });
        
        const verificationOutcome = await tokenVerificationResult.json();
        if (!verificationOutcome.success) {
            return new Response(JSON.stringify({ success: false, error: "Cryptographic validation failed. Bot threat blocked." }), {
                status: 403,
                headers: { "Content-Type": "application/json" }
            });
        }

        // Transaction Execution Tier: Parameterized SQL Mutation on Cloudflare D1 Instance
        const timestampIso = new Date().toISOString();
        const dbResult = await env.DB.prepare(
            "INSERT INTO leads (email, origin, destination, created_at) VALUES (?, ?, ?, ?)"
        ).bind(email.trim().toLowerCase(), origin, destination, timestampIso).run();

        if (!dbResult.success) {
            throw new Error("D1 Relational Ledger internal mutation error encountered.");
        }

        return new Response(JSON.stringify({ success: true, message: "Lead identity registered successfully into secure state." }), {
            status: 201,
            headers: { "Content-Type": "application/json" }
        });

    } catch (globalException) {
        // Enforce strict constraint: Check unique key constraint crash signatures cleanly (e.g. email duplication)
        if (globalException.message && globalException.message.includes("UNIQUE constraint failed")) {
            return new Response(JSON.stringify({ success: false, error: "This specific email asset is already registered inside our launch cohort." }), {
                status: 409,
                headers: { "Content-Type": "application/json" }
            });
        }

        return new Response(JSON.stringify({ success: false, error: "System Core error exception intercepted." }), {
            status: 500,
            headers: { "Content-Type": "application/json" }
        });
    }
}

export async function onRequestGet(context) {
    const { env, request } = context;
    
    try {
        // Administrative Security Handshake Protocol Tier Verification
        const authorizationPayload = request.headers.get("Authorization");
        const expectedHeaderToken = `Bearer ${env.ADMIN_REPORTING_SECRET_TOKEN}`;

        if (!authorizationPayload || authorizationPayload !== expectedHeaderToken) {
            return new Response(JSON.stringify({ success: false, error: "Access Denied: Invalid Administrative Token Credentials." }), {
                status: 401,
                headers: { "Content-Type": "application/json" }
            });
        }

        // Database Selection Query Tier Execution
        const queryOutcome = await env.DB.prepare(
            "SELECT id, email, origin, destination, created_at FROM leads ORDER BY created_at DESC"
        ).all();

        const dataRows = queryOutcome.results || [];

        // Spreadsheet Compilation Engine Execution Lifecycle
        let csvDocumentPayload = "ID,Email,Route Origin,Route Destination,Registration Timestamp\\r\\n";
        
        for (const record of dataRows) {
            // Sanitize string text sequences escaping strings preventing column injection vulnerabilities
            const sanitizedId = String(record.id).replace(/"/g, '""');
            const sanitizedEmail = String(record.email).replace(/"/g, '""');
            const sanitizedOrigin = String(record.origin).replace(/"/g, '""');
            const sanitizedDestination = String(record.destination).replace(/"/g, '""');
            const sanitizedTime = String(record.created_at).replace(/"/g, '""');

            csvDocumentPayload += `"${sanitizedId}","${sanitizedEmail}","${sanitizedOrigin}","${sanitizedDestination}","${sanitizedTime}"\\r\\n`;
        }

        // Timestamp Generation naming download artifact dynamically uniquely
        const exportDateStamp = new Date().toISOString().split('T')[0];
        const filenameStr = `labadi_shipping_leads_export_${exportDateStamp}.csv`;

        // Output Construction: Return binary data mapping standard browser stream actions natively
        return new Response(csvDocumentPayload, {
            status: 200,
            headers: {
                "Content-Type": "text/csv; charset=utf-8",
                "Content-Disposition": `attachment; filename="${filenameStr}"`,
                "Cache-Control": "no-store, must-revalidate"
            }
        });

    } catch (systemException) {
        return new Response(JSON.stringify({ success: false, error: "Internal compilation failure parsing analytical models." }), {
            status: 500,
            headers: { "Content-Type": "application/json" }
        });
    }
}





